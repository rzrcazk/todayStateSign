/* 首页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20px;
  box-sizing: border-box;
}

/* 位置栏 */
.location-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 12px 16px;
  border-radius: 24px;
  margin-bottom: 30px;
}

.location-icon {
  font-size: 16px;
  margin-right: 8px;
}

.location-text {
  color: #fff;
  font-size: 14px;
  font-weight: 500;
}

/* 欢迎语 */
.welcome-section {
  text-align: center;
  margin-bottom: 40px;
}

.welcome-title {
  color: #fff;
  font-size: 28px;
  font-weight: 700;
  display: block;
  margin-bottom: 8px;
}

.welcome-subtitle {
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
}

/* 状态选择区 */
.status-section {
  margin-bottom: 30px;
}

.section-title {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
  display: block;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.status-item {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16px;
  padding: 24px;
  text-align: center;
  transition: all 0.25s ease;
  border: 2px solid transparent;
  position: relative;
}

.status-item.selected {
  background: rgba(255, 255, 255, 0.95);
  border-color: #fff;
  transform: scale(1.05);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
}

/* 选中对勾标记 */
.status-item.selected::after {
  content: '✓';
  position: absolute;
  top: 8px;
  right: 10px;
  font-size: 18px;
  font-weight: 700;
  color: #4ECDC4;
  background: #fff;
  border-radius: 50%;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon {
  font-size: 32px;
  display: block;
  margin-bottom: 8px;
}

.status-name {
  color: #fff;
  font-size: 14px;
  font-weight: 600;
}

.status-item.selected .status-name {
  color: #333;
}

/* 留言输入区 */
.comment-section {
  margin-bottom: 30px;
}

.comment-input {
  width: 100%;
  height: 80px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  padding: 12px;
  color: #fff;
  font-size: 14px;
  box-sizing: border-box;
}

.comment-placeholder {
  color: rgba(255, 255, 255, 0.8);
}

.comment-count {
  color: rgba(255, 255, 255, 0.6);
  font-size: 12px;
  text-align: right;
  margin-top: 8px;
  display: block;
}

/* 打卡按钮 */
.action-section {
  margin-bottom: 20px;
}

.checkin-btn {
  width: 100%;
  height: 52px;
  background: #fff;
  color: #667eea;
  font-size: 18px;
  font-weight: 700;
  border-radius: 26px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.checkin-btn.disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.5);
}

.checkin-btn.loading {
  opacity: 0.7;
}

/* 底部提示 */
.footer-tips {
  text-align: center;
  padding: 20px 0;
}

.footer-tips text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  text-decoration: underline;
}

/* 位置栏可点击样式 */
.location-bar {
  cursor: pointer;
  position: relative;
}

.location-text.loading {
  opacity: 0.7;
}

.location-arrow {
  color: rgba(255, 255, 255, 0.7);
  font-size: 18px;
  margin-left: 8px;
  font-weight: 300;
}

.loading-dot {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-left: 8px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 位置选择器遮罩 */
.location-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 位置选择器弹窗 */
.location-picker {
  width: 85%;
  max-width: 320px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.picker-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 20px;
  color: #999;
  padding: 0 4px;
}

.picker-content {
  padding: 20px;
}

.picker-row {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.picker-row:last-child {
  margin-bottom: 0;
}

.picker-label {
  width: 60px;
  font-size: 15px;
  color: #666;
  font-weight: 500;
}

.picker-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 15px;
  color: #333;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
}

.picker-actions {
  display: flex;
  padding: 16px 20px;
  gap: 12px;
  border-top: 1px solid #f0f0f0;
}

.picker-btn {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  border: none;
  font-size: 15px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-btn::after {
  border: none;
}

.picker-btn-secondary {
  background: #f0f0f0;
  color: #666;
}

.picker-btn-secondary:active {
  background: #e0e0e0;
}

.picker-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.picker-btn-primary:active {
  opacity: 0.9;
}

.btn-icon {
  margin-right: 4px;
  font-size: 14px;
}
